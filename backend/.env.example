# ── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=perfume
DB_PASSWORD=perfume_dev
DB_NAME=perfume

# ── Neo4j ──────────────────────────────────────────────
# Windows users: if port 7687 is reserved, use 17687 instead
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=perfume_dev

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://:perfume_dev@localhost:6379

# ── CORS ────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── App ─────────────────────────────────────────────────
DEBUG=false

# ── LLM (OpenAI-compatible API) ─────────────────────────
# 留空 = 使用模板回退 (STORY_TEMPLATES)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=8.0

# ── Auth ─────────────────────────────────────────────────
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
